# ProbWin AI - environment variables
# Skopiuj ten plik do .env i wypelnij wartosciami

# Claude API (do generowania komentarzy AI). Bez tego klucza aplikacja uzyje mockowanych komentarzy.
ANTHROPIC_API_KEY=

# the-odds-api.com (do pobierania kursow Betclic i listy meczow).
# Darmowy plan: 500 req/mies. Bez klucza uzyte zostana mockowane mecze do demonstracji.
ODDS_API_KEY=

# Region kursow (eu, uk, us). Dla Betclic najlepiej eu
ODDS_API_REGION=eu

# Liga - klucz the-odds-api (zob. https://the-odds-api.com/sports-odds-data/sports-apis.html)
# soccer_epl = Premier League
# soccer_spain_la_liga = La Liga
ODDS_API_SPORT=soccer_epl

# Ile meczow w 'top 10' pokazywac (domyslnie 10)
TOP_N_MATCHES=10

# Sciezka do SQLite (relatywna do glownego folderu projektu)
DATABASE_PATH=backend/db/probwin.sqlite

# Lokalizacja portu HTTP dla FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# Sciezka do cache Clubelo (JSON na dysku)
ELO_CACHE_PATH=backend/data/elo_cache.json

# CORS - lista dozwolonych originow (comma-separated). * = wszystkie (tylko dev)
ALLOWED_ORIGINS=*
