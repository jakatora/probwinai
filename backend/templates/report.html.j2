<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Analiza statystyczna meczu {{ insights.home_team }} vs {{ insights.away_team }} - prawdopodobienstwa wynikow, forma druzyn, H2H.">
<meta name="theme-color" content="#0f1419">
<meta property="og:title" content="{{ insights.home_team }} vs {{ insights.away_team }} - ProbWin AI">
<meta property="og:description" content="Analiza meczu z prawdopodobienstwami statystycznymi i komentarzem AI.">
<meta property="og:type" content="article">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><circle cx='16' cy='16' r='14' fill='%2360a5fa'/><text x='16' y='22' font-family='Arial' font-size='18' font-weight='bold' fill='white' text-anchor='middle'>P</text></svg>">
<title>{{ insights.home_team }} vs {{ insights.away_team }} - ProbWin AI</title>
<style>
:root {
    --bg: #0f1419;
    --panel: #1a212a;
    --panel-2: #232c38;
    --text: #e6edf3;
    --text-dim: #8b9bab;
    --accent: #4ade80;
    --accent-2: #60a5fa;
    --warning: #fbbf24;
    --danger: #f87171;
    --border: #2d3748;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    padding: 16px;
    max-width: 920px;
    margin: 0 auto;
}
header { margin-bottom: 24px; }
.logo {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 1px;
    text-transform: uppercase;
}
h1 {
    font-size: 28px;
    font-weight: 700;
    margin-top: 6px;
    line-height: 1.2;
}
.meta {
    color: var(--text-dim);
    font-size: 14px;
    margin-top: 6px;
}
.card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 16px;
}
.card h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-dim);
    margin-bottom: 14px;
    font-weight: 600;
}

/* Probability comparison */
.prob-row {
    display: grid;
    grid-template-columns: 140px 1fr 70px 70px;
    gap: 12px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
}
.prob-row:last-child { border-bottom: none; }
.prob-row .label { font-weight: 500; }
.prob-bar-container {
    background: var(--panel-2);
    height: 24px;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
}
.prob-bar {
    height: 100%;
    background: var(--accent-2);
    transition: width 0.3s ease;
}
.prob-bar.bookmaker { background: var(--text-dim); }
.prob-value, .prob-odds {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-weight: 600;
}
.prob-odds { color: var(--text-dim); font-weight: 500; }

/* Edge indicator */
.edge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
}
.edge.positive { background: rgba(74, 222, 128, 0.15); color: var(--accent); }
.edge.negative { background: rgba(248, 113, 113, 0.15); color: var(--danger); }
.edge.neutral  { background: rgba(139, 155, 171, 0.15); color: var(--text-dim); }

/* Team panels */
.teams-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}
.team-panel { padding: 16px; background: var(--panel-2); border-radius: 8px; }
.team-name { font-weight: 600; font-size: 16px; margin-bottom: 8px; }
.elo-value { font-size: 24px; font-weight: 700; color: var(--accent-2); }
.elo-label { font-size: 11px; color: var(--text-dim); text-transform: uppercase; }
.form-dots { margin-top: 12px; display: flex; gap: 4px; }
.form-dot {
    width: 24px; height: 24px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 4px;
    font-size: 11px; font-weight: 700;
}
.form-W { background: rgba(74, 222, 128, 0.2); color: var(--accent); }
.form-D { background: rgba(251, 191, 36, 0.2); color: var(--warning); }
.form-L { background: rgba(248, 113, 113, 0.2); color: var(--danger); }
.form-stats { margin-top: 8px; font-size: 13px; color: var(--text-dim); }

/* H2H */
.h2h-row {
    display: grid;
    grid-template-columns: 100px 1fr 60px 1fr;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
}
.h2h-row:last-child { border-bottom: none; }
.h2h-row .h2h-date { color: var(--text-dim); font-size: 12px; }
.h2h-row .h2h-score {
    text-align: center;
    font-weight: 700;
    background: var(--panel-2);
    padding: 4px 8px;
    border-radius: 4px;
    font-variant-numeric: tabular-nums;
}

/* AI commentary */
.commentary {
    background: linear-gradient(135deg, rgba(96, 165, 250, 0.08), rgba(74, 222, 128, 0.05));
    border-left: 3px solid var(--accent-2);
    padding: 16px;
    border-radius: 0 8px 8px 0;
    font-size: 15px;
    line-height: 1.6;
}
.commentary-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--accent-2);
    font-weight: 700;
    margin-bottom: 8px;
    display: block;
}

footer {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-dim);
    text-align: center;
}
.disclaimer { color: var(--warning); margin-top: 8px; }
</style>
</head>
<body>
<header>
    <div class="logo">ProbWin AI</div>
    <h1>{{ insights.home_team }} <span style="color: var(--text-dim);">vs</span> {{ insights.away_team }}</h1>
    <div class="meta">
        {{ insights.league }} &middot; {{ insights.kick_off.strftime('%Y-%m-%d %H:%M') }} UTC
    </div>
</header>

<!-- KOMENTARZ AI -->
{% if insights.ai_commentary %}
<div class="card">
    <h2>Analiza AI</h2>
    <div class="commentary">
        <span class="commentary-label">Komentarz analityka</span>
        {{ insights.ai_commentary | replace('\n', '<br>') | safe }}
    </div>
</div>
{% endif %}

<!-- PRAWDOPODOBIENSTWA -->
<div class="card">
    <h2>Prawdopodobienstwo wyniku</h2>
    {% set outcomes = [
        ('Gospodarz (1)', insights.home_team, insights.model_probability.home, insights.implied_probability.home, insights.bookmaker_odds.home, 'home'),
        ('Remis (X)', 'Remis', insights.model_probability.draw, insights.implied_probability.draw, insights.bookmaker_odds.draw, 'draw'),
        ('Gosc (2)', insights.away_team, insights.model_probability.away, insights.implied_probability.away, insights.bookmaker_odds.away, 'away')
    ] %}

    <div class="prob-row" style="font-size: 12px; color: var(--text-dim); text-transform: uppercase; border-bottom: 1px solid var(--border); padding-bottom: 10px;">
        <div>Wynik</div>
        <div>Model ProbWin AI</div>
        <div style="text-align: right;">Kurs</div>
        <div style="text-align: right;">Edge</div>
    </div>

    {% for label, team, model_p, implied_p, odds, key in outcomes %}
    <div class="prob-row">
        <div class="label">{{ label }}</div>
        <div>
            <div class="prob-bar-container" title="Model: {{ '%.1f' | format(model_p * 100) }}% &middot; Bukmacher: {{ '%.1f' | format(implied_p * 100) }}%">
                <div class="prob-bar" style="width: {{ model_p * 100 }}%;"></div>
            </div>
            <div style="display: flex; justify-content: space-between; margin-top: 4px; font-size: 12px;">
                <span class="prob-value">Model: {{ '%.1f' | format(model_p * 100) }}%</span>
                <span style="color: var(--text-dim);">Bukmacher: {{ '%.1f' | format(implied_p * 100) }}%</span>
            </div>
        </div>
        <div class="prob-odds">{{ '%.2f' | format(odds) }}</div>
        <div style="text-align: right;">
            {% set edge = (model_p - implied_p) * 100 %}
            {% if edge > 3 %}
                <span class="edge positive">+{{ '%.1f' | format(edge) }}%</span>
            {% elif edge < -3 %}
                <span class="edge negative">{{ '%.1f' | format(edge) }}%</span>
            {% else %}
                <span class="edge neutral">{{ '%.1f' | format(edge) }}%</span>
            {% endif %}
        </div>
    </div>
    {% endfor %}

    <div style="margin-top: 14px; font-size: 12px; color: var(--text-dim);">
        Marza bukmachera (vig): {{ '%.2f' | format(insights.vig_pct) }}% &middot; Bukmacher: {{ insights.bookmaker_odds.bookmaker }}
    </div>
</div>

<!-- DRUZYNY -->
<div class="card">
    <h2>Druzyny</h2>
    <div class="teams-grid">
        {% for ctx in [insights.home_context, insights.away_context] %}
        <div class="team-panel">
            <div class="team-name">{{ ctx.name }}</div>
            {% if ctx.elo %}
            <div class="elo-value">{{ '%.0f' | format(ctx.elo) }}</div>
            <div class="elo-label">Rating Elo (Clubelo)</div>
            {% else %}
            <div class="elo-label" style="color: var(--text-dim);">Brak danych Elo</div>
            {% endif %}

            {% if ctx.form %}
            <div class="form-dots">
                {% for r in ctx.form.results %}
                <div class="form-dot form-{{ r }}" title="{{ r }}">{{ r }}</div>
                {% endfor %}
            </div>
            <div class="form-stats">
                {{ ctx.form.points }} pkt &middot;
                {{ ctx.form.goals_for }}-{{ ctx.form.goals_against }} ({{ '%.1f' | format(ctx.form.avg_gf) }} GF, {{ '%.1f' | format(ctx.form.avg_ga) }} GA)
            </div>
            {% else %}
            <div class="form-stats" style="margin-top: 12px;">Brak danych o formie</div>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>

<!-- H2H -->
{% if insights.h2h %}
<div class="card">
    <h2>Ostatnie spotkania bezposrednie</h2>
    {% for m in insights.h2h | reverse %}
    <div class="h2h-row">
        <div class="h2h-date">{{ m.date.strftime('%Y-%m-%d') }}</div>
        <div style="text-align: right;">{{ m.home_team }}</div>
        <div class="h2h-score">{{ m.result_string() }}</div>
        <div>{{ m.away_team }}</div>
    </div>
    {% endfor %}
</div>
{% endif %}

<footer>
    Wygenerowano: {{ insights.generated_at.strftime('%Y-%m-%d %H:%M UTC') }}
    <div class="disclaimer">
        ProbWin AI to narzedzie informacyjne. Nie rekomenduje zakladow.
        Hazard moze uzalezniać. Graj odpowiedzialnie.
    </div>
</footer>
</body>
</html>
